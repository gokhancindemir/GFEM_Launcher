{
  "name": "gfem_launcher",
  "version": "1.0.0",
  "description": "GFEM; Launcher",
  "author": "Gökhan Çindemir",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "obfuscate": "npx javascript-obfuscator ./main.js --output ./main.js",
    "build": "npx electron-builder"
  },
  "build": {
    "appId": "com.gfem.launcher",
    "productName": "GFEM_Launcher",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "GFEM_Launcher",
      "installerIcon": "assets/icons/icon.ico",
      "uninstallerIcon": "assets/icons/icon.ico",
      "installerSidebar": "assets/icons/sidebar.bmp",
      "installerHeader": "assets/icons/header.png",
      "uninstallDisplayName": "GFEM_Launcher",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "systeminformation": "^5.21.22"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^4.1.0"
  }
}
